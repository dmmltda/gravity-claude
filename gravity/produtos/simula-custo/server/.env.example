# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Para rodar local com Docker:
#   docker run --name gravity-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=simulacusto -p 5432:5432 -d postgres:16
#
# Para rodar local com PostgreSQL instalado:
#   createdb simulacusto
#
SIMULA_CUSTO_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/simulacusto

# ─── Auth entre serviços ──────────────────────────────────────────────────────
# Qualquer string serve para desenvolvimento local
INTERNAL_SERVICE_KEY=dev-local-key

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
