{
  "name": "@gravity/simula-custo-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":          "tsx watch index.ts",
    "start":        "node dist/index.js",
    "build":        "tsc",
    "db:generate":  "prisma generate --schema prisma/schema.dev.prisma",
    "db:push":      "prisma db push --schema prisma/schema.dev.prisma",
    "db:studio":    "prisma studio --schema prisma/schema.dev.prisma",
    "db:generate:prod": "prisma generate --schema prisma/schema.prisma",
    "db:push:prod":     "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "express":        "^4.18.0",
    "zod":            "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node":    "^20.0.0",
    "prisma":         "^5.0.0",
    "tsx":            "^4.7.0",
    "typescript":     "^5.5.4"
  }
}
