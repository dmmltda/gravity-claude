# ─────────────────────────────────────────────
# Gravity — Variáveis de Ambiente
# Copie para .env e preencha os valores reais.
# Nunca commite o .env com valores reais.
# ─────────────────────────────────────────────

# Servidor
# PORT=3000

# Auth entre serviços (compartilhada internamente)
# INTERNAL_API_KEY=
# INTERNAL_SERVICE_KEY=gerar-chave-aleatoria-32-chars
# JWT_SERVICE_SECRET=gerar-chave-aleatoria-32-chars

# Bancos de dados
# TENANT_DATABASE_URL=postgresql://user:password@host:5432/tenant-db
# CONFIGURADOR_DATABASE_URL=postgresql://user:password@host:5432/configurador-db
# SIMULA_CUSTO_DATABASE_URL=postgresql://user:password@host:5432/simula-custo-db

# Clerk (autenticação de usuários)
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
# CLERK_WEBHOOK_SECRET=whsec_...

# Stripe (billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Resend (emails transacionais)
# RESEND_API_KEY=

# WhatsApp (Meta Cloud API)
# META_WHATSAPP_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=

# IA
# OPENAI_API_KEY=sk-...

# Sentry (monitoramento de erros)
# SENTRY_DSN=

# Frontend
# VITE_CONFIGURADOR_URL=

# SimulaCusto — Portal Único / Captcha
# PORTAL_UNICO_CERT_PFX=base64-do-pfx
# PORTAL_UNICO_CERT_SENHA=senha-do-cert
# PORTAL_UNICO_HCAPTCHA_SITE_KEY=
# CAPSOLVER_API_KEY=CAP-...
# ANTICAPTCHA_API_KEY=

# SimulaCusto — Câmbio
# BACEN_URL=https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata
# CAMBIO_USD_FALLBACK=6.00

# URLs internas (Railway private network)
# TENANT_SERVICES_URL=http://tenant-services.railway.internal:3001
# CONFIGURATOR_URL=http://configurador.railway.internal:3000

# E2E Tests
# E2E_BASE_URL=http://localhost:3000
# E2E_USER_EMAIL=test@example.com
# E2E_USER_PASSWORD=senha-de-teste
