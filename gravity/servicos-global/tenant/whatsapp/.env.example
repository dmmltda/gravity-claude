# ─── Meta Cloud API ────────────────────────────────────────────────────────────
# System User Access Token PERMANENTE — gerado no Meta Business Manager
# ATENÇÃO: tokens temporários expiram em 60 dias e causam falhas silenciosas
WHATSAPP_ACCESS_TOKEN=

# ID do número de telefone business registrado na Meta
WHATSAPP_PHONE_NUMBER_ID=

# Segredo do App Meta — usado para validar HMAC-SHA256 do webhook
WHATSAPP_APP_SECRET=

# Token livre definido por você — deve coincidir com o configurado no painel Meta
WHATSAPP_VERIFY_TOKEN=

# ─── Limites e alertas de custo ────────────────────────────────────────────────
# Limite mensal de gasto em USD
WHATSAPP_MONTHLY_LIMIT_USD=20

# Percentual do limite que dispara alerta de email (0–100)
WHATSAPP_ALERT_PCT=80

# Email que recebe o alerta de custo
WHATSAPP_ALERT_EMAIL=

# ─── Roteamento de tenant (multi-tenant) ──────────────────────────────────────
# Usado temporariamente para resolver tenant em webhooks inbound
# TODO(daniel, 2026-03): substituir por service registry
DEFAULT_TENANT_ID=
