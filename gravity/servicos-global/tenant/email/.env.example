# ─── Resend ───────────────────────────────────────────────────────────────────
# Chave de API do Resend (obrigatória)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Segredo para verificação de assinatura dos webhooks inbound do Resend
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endereço de remetente padrão (ex: "Empresa <aviso@resend.dev>")
EMAIL_FROM=Empresa <aviso@resend.dev>

# Endereço base para Reply-To dinâmico com UUID.
# Quando configurado, cada email enviado terá reply+{uuid}@dominio.com.br
# Se não configurado, o serviço de inbound não consegue vincular respostas a threads.
EMAIL_INBOUND_ADDRESS=reply@dominio.com.br

# ─── Banco de Dados ────────────────────────────────────────────────────────────
# URL de conexão com o banco de dados do tenant (PostgreSQL)
TENANT_DATABASE_URL=postgresql://user:password@localhost:5432/tenant_db

# ─── Gabi — Limites de Custo ──────────────────────────────────────────────────
# Limite mensal de custo da Gabi em USD (padrão: 20)
GABI_MONTHLY_LIMIT_USD=20

# Percentual do limite que dispara alerta por email (padrão: 80)
GABI_ALERT_PCT=80

# Email que recebe alertas de custo da Gabi e alertas de sentimento negativo
GABI_ALERT_EMAIL=admin@empresa.com.br

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Chave de API do Google Gemini (para análise da Gabi)
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── Multi-tenant ─────────────────────────────────────────────────────────────
# Tenant padrão para emails sem Reply-To dinâmico rastreável
# (fallback temporário — substituir por roteamento multi-tenant real)
DEFAULT_TENANT_ID=

# ─── x-internal-key ───────────────────────────────────────────────────────────
# Chave compartilhada entre serviços internos (autenticação S2S)
INTERNAL_SERVICE_KEY=internal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
