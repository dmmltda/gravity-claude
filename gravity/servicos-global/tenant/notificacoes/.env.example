# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=development

# ── Banco de dados (shared tenant-db) ─────────────────────────────────────────
# Usado pelo Prisma e pelo pg-boss para a fila de jobs
TENANT_DATABASE_URL=postgresql://user:password@localhost:5432/tenant_db

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Chave secreta para lookup de usuários via API do Clerk
CLERK_SECRET_KEY=sk_test_...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Gravity <noreply@gravity.app>

# ── WhatsApp — Meta Cloud API ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
