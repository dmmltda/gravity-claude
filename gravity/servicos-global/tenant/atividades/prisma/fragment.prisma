// servicos-global/tenant/atividades/prisma/fragment.prisma
// Composto pelo Coordenador via scripts/compose-tenant-schema.ts — não editar schema.prisma diretamente.

model Activity {
  id          String    @id @default(cuid())
  tenant_id   String
  product_id  String?
  user_id     String

  title       String
  description String?
  status      String    // pending | in_progress | done | cancelled

  due_date    DateTime?

  // Lembrete
  reminder_at            DateTime?
  reminder_sent          Boolean   @default(false)
  reminder_whatsapp      Boolean   @default(false)

  // Próximo passo
  next_step                  String?
  next_step_date             DateTime?
  next_step_reminder_sent    Boolean   @default(false)

  // WhatsApp de reunião
  send_invite_whatsapp    Boolean   @default(false)
  send_summary_whatsapp   Boolean   @default(false)
  send_recording_whatsapp Boolean   @default(false)
  recording_url           String?
  recording_sent          Boolean   @default(false)

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  // Índices obrigatórios de tenant
  @@index([tenant_id])
  @@index([tenant_id, product_id])
  @@index([tenant_id, user_id])

  // Índices de negócio
  @@index([tenant_id, status])
  @@index([tenant_id, due_date])
}
